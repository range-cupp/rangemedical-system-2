# Range Medical Report Engine — Environment Variables
# Copy this file to .env in the scripts/ directory and fill in the values.
# Never commit .env to git.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/teivfptpozltpqwahgdl/settings/api
SUPABASE_URL=https://teivfptpozltpqwahgdl.supabase.co
SUPABASE_SERVICE_KEY=          # Settings > API > service_role key (secret — not the anon key)

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get API key from: https://resend.com/api-keys
# Verify the sender domain at: https://resend.com/domains
RESEND_API_KEY=re_...
DIGEST_FROM=reports@range-medical.com
DIGEST_TO=cupp@range-medical.com

# ── Optional overrides ────────────────────────────────────────────────────────
# COSTS_JSON_PATH=../pricing/costs 2.json   # default: relative to scripts/
# TZ=America/Los_Angeles                    # recommended for correct date math
